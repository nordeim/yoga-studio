{
  "name": "fitness-studio",
  "version": "0.1.0",
  "private": true,
  "description": "IRONFORGE — high-end fitness studio brand official website. Hardcore, motivating, professional. Built with Next.js 16, React 19, Tailwind CSS v4, Drizzle ORM, Auth.js v5, Inngest, Stripe, Replicate.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.26.0"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test --config=playwright-live.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "drizzle:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "drizzle:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "drizzle:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- tsx src/lib/db/seed.ts",
    "db:reset": "pnpm drizzle:migrate && pnpm db:seed",
    "analyze": "ANALYZE=true next build",
    "audit:security": "tsx scripts/security-audit.ts",
    "audit:a11y": "tsx scripts/accessibility-audit.ts",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,mjs}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.7.0",
    "inngest": "^4.11.0",
    "lucide-react": "^0.460.0",
    "next": "^16.2.0",
    "next-auth": "5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "replicate": "^1.4.0",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^9.39.4",
    "@next/bundle-analyzer": "^16.2.10",
    "@next/eslint-plugin-next": "^16.2.9",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "esbuild": ">=0.25.0"
    }
  }
}
