# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Python
__pycache__/
*.py[cod]

# Build artifacts — package the skill on demand, don't commit a stale bundle
*.skill

# Skill-creator / eval scratch (regenerable; may contain machine-local paths)
*-workspace/
feedback.json
*.log

# Loop *state* is changing data, never durable knowledge — never commit a loop's
# runtime state into version control. (Kept out of this repo by design.)
loops/*/runs/

# Understand Anything — generated knowledge graph + analysis scratch (regenerable)
.understand-anything/
